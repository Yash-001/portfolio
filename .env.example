# ── App ───────────────────────────────────────────────────────────────────
VITE_APP_TITLE=Yash Ranjan | Enterprise Software & AI Consultant
VITE_APP_URL=https://yourdomain.com
VITE_APP_EMAIL=yash.ranjan.dev@proton.me

# ── EmailJS (https://www.emailjs.com) ─────────────────────────────────────
# 1. Create a free account at emailjs.com
# 2. Add an Email Service (Gmail, Outlook, etc.) → copy the Service ID
# 3. Create an Email Template → copy the Template ID
# 4. Go to Account → API Keys → copy the Public Key
#
# Required template variables (map these in your EmailJS template):
#   {{from_name}}    — sender's full name
#   {{from_email}}   — sender's email address
#   {{project_type}} — selected project type
#   {{budget}}       — selected budget range
#   {{message}}      — message body
#   {{reply_to}}     — reply-to address (same as from_email)
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx

# ── Calendly ──────────────────────────────────────────────────────────────
# Your Calendly scheduling link (e.g. https://calendly.com/yourname/30min)
VITE_CALENDLY_URL=https://calendly.com/yourname/30min

# ── Analytics ─────────────────────────────────────────────────────────────
# Google Analytics 4 — https://analytics.google.com
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Plausible Analytics — https://plausible.io (use your site domain, e.g. yourdomain.com)
VITE_PLAUSIBLE_DOMAIN=yourdomain.com

# Microsoft Clarity — https://clarity.microsoft.com (Project ID from Settings > Overview)
VITE_CLARITY_PROJECT_ID=xxxxxxxxxx

# Set to "true" to enable analytics in local dev (default: off in dev)
VITE_ANALYTICS_DEV=false

# ── Blog API (optional) ───────────────────────────────────────────────────
VITE_BLOG_API_URL=https://api.yourdomain.com
